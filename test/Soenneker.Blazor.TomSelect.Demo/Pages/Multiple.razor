@page "/multiple"
@using Microsoft.Extensions.Logging
@using Soenneker.Blazor.TomSelect.Configuration
@using Soenneker.Blazor.TomSelect.Demo.Dtos
@using Soenneker.Blazor.TomSelect.Dtos
@using Soenneker.Blazor.TomSelect.Enums
@using Soenneker.Extensions.Enumerable
@using Soenneker.Utils.AutoBogus
@using Soenneker.Blazor.Utils.Ids

@inject ILogger<Index> Logger
@inject HttpClient Http

<Div Space="Space.Y.Is6">
    <Div Space="Space.Y.Is2">
        <H1 TextSize="TextSize.TwoXl" FontWeight="FontWeight.Semibold" Margin="Margin.Is0">Multiple TomSelect components</H1>
        <Paragraph Margin="Margin.Is0" TextColor="TextColor.MutedForeground" TextSize="TextSize.Sm">
            Six independent multi-select instances initialized together on one page. Controls target the first instance.
        </Paragraph>
    </Div>

    @if (_render)
    {
        @if (_countries.Populated())
        {
            <DemoPanel Title="Six initialized TomSelects" Description="@GetInitializationStatus()">
            <Div Class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                @foreach (int instanceNumber in InstanceNumbers)
                {
                    bool isPrimary = instanceNumber == 1;

                    <Div Class="space-y-2">
                        <Div Space="Space.Y.Is1">
                            <Paragraph Margin="Margin.Is0" FontWeight="FontWeight.Medium">
                                @GetPanelTitle(instanceNumber)
                            </Paragraph>
                            <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                                @GetPanelDescription(instanceNumber)
                            </Paragraph>
                        </Div>

                        @if (isPrimary)
                        {
                            <TomSelect
                                @key="instanceNumber"
                                @ref="_tomSelect"
                                TItem="Country"
                                TType="string"
                                OnInitialize="@(() => OnTomSelectInitialized(instanceNumber))"
                                OnOptionRemove="OnOptionRemove"
                                OnItemRemove="OnItemRemove"
                                OnOptionAdd="OnOptionAdd"
                                OnItemCreated="OnItemCreated"
                                OnItemAdd="OnItemAdd"
                                Data="@_countries"
                                Items="@_selectedItemsByInstance[instanceNumber - 1]"
                                ItemsChanged="@(items => OnItemsChanged(instanceNumber, items))"
                                TextField="item => item.Name"
                                ValueField="item => item.Id.ToString()"
                                CreateFuncSync="CreateCountryFromText"
                                Multiple="true"
                                Create="true"
                                OnChange="OnChange"
                                Debug=true
                                PlaceHolder="@GetPlaceholder(instanceNumber)"
                                Configuration="@_configurations[instanceNumber - 1]">
                            </TomSelect>
                        }
                        else
                        {
                            <TomSelect
                                @key="instanceNumber"
                                TItem="Country"
                                TType="string"
                                OnInitialize="@(() => OnTomSelectInitialized(instanceNumber))"
                                OnOptionRemove="OnOptionRemove"
                                OnItemRemove="OnItemRemove"
                                OnOptionAdd="OnOptionAdd"
                                OnItemCreated="OnItemCreated"
                                OnItemAdd="OnItemAdd"
                                Data="@_countries"
                                Items="@_selectedItemsByInstance[instanceNumber - 1]"
                                ItemsChanged="@(items => OnItemsChanged(instanceNumber, items))"
                                TextField="item => item.Name"
                                ValueField="item => item.Id.ToString()"
                                CreateFuncSync="CreateCountryFromText"
                                Multiple="true"
                                Create="true"
                                OnChange="OnChange"
                                Debug=true
                                PlaceHolder="@GetPlaceholder(instanceNumber)"
                                Configuration="@_configurations[instanceNumber - 1]">
                            </TomSelect>
                        }
                    </Div>
                }
            </Div>
            </DemoPanel>
        }

        <DemoPanel Title="Component controls (first instance)" Description="Programmatic operations on the first TomSelect only.">
            <DemoButtonRow>
                <Button OnClick="AddOption">Add option</Button>
                <Button OnClick="AddExistingItem" Variant="ButtonVariant.Secondary">Add existing item</Button>
                <Button OnClick="GetItems" Variant="ButtonVariant.Outline">Get items</Button>
            </DemoButtonRow>
            <DemoButtonRow>
                <Button OnClick="Render" Variant="ButtonVariant.Secondary">Toggle render</Button>
                <Button OnClick="ClearViaData" Variant="ButtonVariant.Secondary">Clear via data</Button>
                <Button OnClick="AddViaData" Variant="ButtonVariant.Secondary">Add via data</Button>
            </DemoButtonRow>
            <DemoButtonRow>
                <Button OnClick="async () => await ClearItems()" Variant="ButtonVariant.Destructive">Clear items</Button>
                <Button OnClick="ClearOptions" Variant="ButtonVariant.Destructive">Clear options</Button>
                <Button OnClick="Reinitialize" Variant="ButtonVariant.Secondary">Reinitialize</Button>
                <Button OnClick="SetOptionsAndItems" Variant="ButtonVariant.Secondary">Reset data</Button>
            </DemoButtonRow>
        </DemoPanel>

        <DemoPanel Title="Modal example" Description="TomSelect inside the shared modal.">
            <DemoButtonRow>
                <Button OnClick="OpenModal">Open modal</Button>
            </DemoButtonRow>
        </DemoPanel>
    }
</Div>

<TomSelectModal @ref="_tomSelectModal" />

@code{
    private List<Country>? _countries;
    private AutoFaker _autoFaker = null!;
    private TomSelect<Country, string> _tomSelect = null!;
    private bool _render = true;
    private TomSelectModal? _tomSelectModal;
    private readonly HashSet<int> _initializedInstances = [];
    private List<List<Country>> _selectedItemsByInstance = CreateEmptySelectedItemLists();

    private const int InstanceCount = 6;
    private static readonly int[] InstanceNumbers = [1, 2, 3, 4, 5, 6];

    private readonly TomSelectConfiguration[] _configurations =
    [
        CreateConfiguration(),
        CreateConfiguration(),
        CreateConfiguration(),
        CreateConfiguration(),
        CreateConfiguration(),
        CreateConfiguration()
    ];

    protected override void OnInitialized()
    {
        _autoFaker = new AutoFaker();
    }

    protected override async Task OnInitializedAsync()
    {
        await SetOptionsAndItems();
    }

    private async Task SetOptionsAndItems()
    {
        _countries = await Http.GetFromJsonAsync<List<Country>>("sample-data/countries.json");
        _selectedItemsByInstance = CreateSelectedItemLists(_countries!);
    }

    private async Task OpenModal()
    {
        await _tomSelectModal!.Show();
    }

    private Country CreateCountryFromText(string text) => new() { Name = text, Id = BlazorIdGenerator.New("country") };

    private void OnTomSelectInitialized(int instanceNumber)
    {
        _initializedInstances.Add(instanceNumber);

        Logger.LogInformation("TomSelect instance {InstanceNumber} initialized", instanceNumber);
    }

    private void ClearViaData()
    {
        _selectedItemsByInstance[0] = [];
    }

    private async Task AddViaData()
    {
        var countries = await Http.GetFromJsonAsync<List<Country>>("sample-data/countries.json");
        _selectedItemsByInstance[0] = [.. _selectedItemsByInstance[0], countries!.GetRandom()!];
    }

    private async ValueTask ClearItems()
    {
        await _tomSelect.ClearItems();
    }

    private async Task ClearOptions()
    {
        await _tomSelect.ClearOptions();
    }

    private async Task Reinitialize()
    {
        await _tomSelect.Reinitialize();
    }

    private void Render()
    {
        _render = !_render;
    }

    private void OnOptionAdd((string str, TomSelectOption obj) result)
    {
        Logger.LogInformation("OnOptionAdd called");
    }

    private void OnItemAdd((string str, TomSelectOption obj) result)
    {
        Logger.LogInformation("OnItemAdd called");
    }

    private void OnOptionRemove(string result)
    {
        Logger.LogInformation("OnOptionRemove called");
    }

    private void OnItemRemove((string str, TomSelectOption obj) result)
    {
        Logger.LogInformation("OnItemRemove called");
    }

    private void OnItemCreated((string str, TomSelectOption obj) result)
    {
        Logger.LogInformation("OnItemCreated called");
    }

    private void OnChange()
    {
        Logger.LogInformation("OnChange called");
    }

    private void OnItemsChanged(int instanceNumber, List<Country> items)
    {
        _selectedItemsByInstance[instanceNumber - 1] = items;
    }

    private async Task AddExistingItem()
    {
        await _tomSelect.AddItem(_tomSelect.Data.GetRandom()!.Id);
    }

    private async Task AddOption()
    {
        await _tomSelect.AddOption(_autoFaker.Generate<Country>());
    }

    private void GetItems()
    {
        if (_tomSelect.Items.Count == 0)
        {
            Logger.LogInformation("No items selected");
            return;
        }

        foreach (Country item in _tomSelect.Items)
        {
            Logger.LogInformation("_tomSelect.Item: {0}", item.Name);
        }
    }

    private static TomSelectConfiguration CreateConfiguration() =>
        new()
        {
            Plugins = [TomSelectPluginType.DragDrop],
            UseCdn = true,
            UseBootstrap5Styling = false
        };

    private static string GetPanelTitle(int instanceNumber) => instanceNumber == 1 ? "TomSelect 1 (primary)" : $"TomSelect {instanceNumber}";

    private static string GetPanelDescription(int instanceNumber) =>
        instanceNumber == 1 ? "Primary instance referenced by the control buttons." : "Same data and behavior; separate TomSelect instance.";

    private static string GetPlaceholder(int instanceNumber) => $"Select or create countries in instance {instanceNumber}...";

    private string GetInitializationStatus() => $"Initialized {_initializedInstances.Count} of {InstanceCount} instances. Controls target the first instance.";

    private static List<List<Country>> CreateEmptySelectedItemLists() =>
        Enumerable.Range(0, InstanceCount)
                  .Select(_ => new List<Country>())
                  .ToList();

    private static List<List<Country>> CreateSelectedItemLists(IReadOnlyList<Country> countries) =>
        InstanceNumbers.Select(instanceNumber => countries.Skip(instanceNumber - 1)
                                                          .Take(2)
                                                          .ToList())
                       .ToList();
}
